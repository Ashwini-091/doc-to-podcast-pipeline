# Doc-to-Podcast Pipeline Configuration
# Copy this file to .env and fill in your values

# Required: Your Groq API key (FREE!)
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=gsk-your-key-here

# Optional: Groq model to use
# Options: mixtral-8x7b-32768 (fastest, balanced)
#          llama2-70b-4096 (better quality, slower)
#          gemma-7b-it (lightweight, faster)
GROQ_MODEL=mixtral-8x7b-32768

# Optional: Text-to-Speech service
# Options: gtts (Google, requires internet, higher quality)
#          pyttsx3 (offline, local, lower quality)
TTS_SERVICE=gtts

# Optional: Maximum script revisions (safety guard)
# Prevents infinite revision loops (1-5 recommended)
MAX_ITERATIONS=3

# Optional: Document chunking size (in tokens)
# Larger = more context per query, fewer API calls
# Smaller = more precise retrieval, more queries
CHUNK_SIZE=512

# Optional: Embedding model for similarity search
# Options: all-MiniLM-L6-v2 (fast, 384-dim, recommended)
#          all-mpnet-base-v2 (slower, better quality, 768-dim)
#          paraphrase-MiniLM-L6-v2 (specialized for paraphrasing)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: Number of chunks to retrieve for context
# Larger = more context, slower, more tokens
# Smaller = faster, less context
RETRIEVAL_TOP_K=5

# Optional: Maximum tokens for retrieved context
# Limits token usage per expansion stage
MAX_CONTEXT_TOKENS=2000

# Optional: Debug logging
# Options: true, false
DEBUG=false
